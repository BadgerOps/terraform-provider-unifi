TF_ACC=1
UNIFI_API_URL=https://unifi.example.com
UNIFI_API_KEY=replace-me
UNIFI_ALLOW_INSECURE=false

# Set exactly one site selector for acceptance tests.
UNIFI_TEST_SITE_ID=
UNIFI_TEST_SITE_NAME=Terraform Acceptance

# Prefix used for ephemeral acceptance resources.
UNIFI_TEST_NAME_PREFIX=acctest-

# Optional today, but useful for future WiFi/controller-backed tests.
UNIFI_TEST_WIFI_PASSPHRASE=replace-with-strong-passphrase

# Enable live tests that require Zone Based Firewall to be configured on the site.
UNIFI_TEST_ENABLE_ZONE_FIREWALL=false
